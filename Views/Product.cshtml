@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.Product>
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels

@{
    Layout = "master.cshtml";
}

<header class="masthead">
    <div class="container">
        <h1>@Model.Name</h1>
    </div>
</header>

<div class="container">
    <div class="row">
        <div class="col-md-6">
            @{
                var image = Model.Value<IPublishedContent>("productImage");
                if (image != null)
                {
                    <img src="@image.Url()" class="img-fluid" />
                }
            }
        </div>
        <div class="col-md-6">
            <h3>@Model.Value("colorName") (@Model.Value("colorCode"))</h3>
            <p>Make: @Model.Value("make")</p>
            <p>Type: @Model.Value("productType")</p>
            <p>@Model.Value("description")</p>
            <h4>@(Model.Value<decimal>("price").ToString("C"))</h4>
            <button class="btn btn-primary">Add to Cart</button>
        </div>
    </div>
</div>